{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Requisicoes por segundo",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sum(rate(prf_api_requests_total[1m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "Latencia p95 da API",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(prf_api_request_duration_seconds_bucket[5m])))",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "CPU por container",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[1m])) * 100",
        "legendFormat": "{{name}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "percent"}},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Memoria por container",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "expr": "container_memory_working_set_bytes{name!=\"\"}",
        "legendFormat": "{{name}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9}
    },
    {
      "type": "timeseries",
      "title": "Tempo de resposta por rota",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "expr": "sum by (path) (rate(prf_api_request_duration_seconds_sum[5m])) / sum by (path) (rate(prf_api_request_duration_seconds_count[5m]))",
        "legendFormat": "{{path}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9}
    },
    {
      "type": "timeseries",
      "title": "Conexoes PostgreSQL",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "expr": "sum by (datname) (pg_stat_database_numbackends{datname=\"prf\"})",
        "legendFormat": "{{datname}}",
        "refId": "A"
      }],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18}
    },
    {
      "type": "timeseries",
      "title": "Transacoes PostgreSQL",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "expr": "rate(pg_stat_database_xact_commit{datname=\"prf\"}[5m]) + rate(pg_stat_database_xact_rollback{datname=\"prf\"}[5m])",
        "legendFormat": "transacoes/s",
        "refId": "A"
      }],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18}
    }
  ],
  "refresh": "5s",
  "schemaVersion": 41,
  "tags": ["prf", "containers", "performance"],
  "templating": {
    "list": [{
      "name": "DS_PROMETHEUS",
      "type": "datasource",
      "query": "prometheus",
      "current": {"text": "Prometheus", "value": "Prometheus"}
    }]
  },
  "time": {"from": "now-30m", "to": "now"},
  "title": "PRF - Desempenho da aplicacao e containers",
  "uid": "prf-performance",
  "version": 1
}
